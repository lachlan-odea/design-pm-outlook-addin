{
  "name": "design-pm-outlook-addin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "certs:install": "office-addin-dev-certs install",
    "certs:uninstall": "office-addin-dev-certs uninstall",
    "manifest:dev": "node scripts/build-manifest.mjs dev",
    "manifest:prod": "node scripts/build-manifest.mjs prod",
    "manifest:validate": "office-addin-manifest validate manifest.dev.xml",
    "predev": "npm run icons",
    "prebuild": "npm run icons",
    "dev": "vite --host localhost --port 3000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/office-js": "^1.0.435",
    "office-addin-dev-certs": "^2.0.0",
    "office-addin-manifest": "^2.1.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
